# =============================================================================
# CDSIP — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in values.
# NEVER commit the .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://cdsip:cdsip_dev_password@localhost:5432/cdsip
POSTGRES_USER=cdsip
POSTGRES_PASSWORD=cdsip_dev_password
POSTGRES_DB=cdsip

# -----------------------------------------------------------------------------
# Rust API Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
API_LOG_LEVEL=debug
RUST_LOG=cdsip_api=debug,tower_http=debug

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a strong secret for production
# openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND
JWT_ACCESS_TOKEN_EXPIRY_SECS=900
JWT_REFRESH_TOKEN_EXPIRY_SECS=604800

# -----------------------------------------------------------------------------
# Environment Mode
# -----------------------------------------------------------------------------
# Values: production | staging | lab | development
CDSIP_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Admin Seed (Development Only)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cdsip.local
ADMIN_PASSWORD=CHANGE_ME_admin_dev_password

# -----------------------------------------------------------------------------
# Python Intelligence Service
# -----------------------------------------------------------------------------
INTEL_SERVICE_HOST=0.0.0.0
INTEL_SERVICE_PORT=8081
INTEL_SERVICE_URL=http://intel:8081

# -----------------------------------------------------------------------------
# Tool Broker — Nmap
# -----------------------------------------------------------------------------
NMAP_BINARY_PATH=/usr/bin/nmap
NMAP_TIMEOUT_SECS=300
NMAP_MAX_CONCURRENT=2

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_SCAN_REQUESTS_PER_HOUR=10
